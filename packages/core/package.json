{
  "name": "@saas/core",
  "version": "0.1.0",
  "private": true,
  "description": "Shared services, DI container, hooks, plugins, and utilities for all backend apps",
  "type": "module",
  "exports": {
    ".": {
      "import": "./src/index.ts",
      "require": "./src/index.ts",
      "types": "./src/index.ts"
    }
  },
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@saas/config": "workspace:*",
    "@saas/db": "workspace:*",
    "@fastify/cookie": "^11.0.0",
    "@fastify/cors": "^11.0.0",
    "@fastify/helmet": "^13.0.0",
    "@fastify/jwt": "^10.0.0",
    "@fastify/rate-limit": "^10.0.0",
    "@fastify/swagger": "^9.0.0",
    "@fastify/swagger-ui": "^5.0.0",
    "fastify": "^5.2.1",
    "inversify": "^6.0.2",
    "nodemailer": "^6.9.0",
    "pino": "^9.3.0",
    "pino-pretty": "^11.2.0",
    "prom-client": "^15.1.3",
    "reflect-metadata": "^0.2.2",
    "stripe": "^16.5.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/nodemailer": "^6.4.0",
    "typescript": "^5.4.0",
    "vitest": "^2.0.0"
  }
}
