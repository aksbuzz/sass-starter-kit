{
  "name": "@saas/db",
  "version": "0.1.0",
  "private": true,
  "description": "Database migrations, schema, and typed client (dbmate + postgres.js)",
  "type": "module",
  "exports": {
    ".": {
      "import":  "./src/index.ts",
      "require": "./src/index.ts",
      "types":   "./src/index.ts"
    }
  },
  "scripts": {
    "db:migrate": "dbmate --url \"$DATABASE_URL\" --migrations-dir ./migrations --schema-file ./schema.sql up",
    "db:rollback": "dbmate --url \"$DATABASE_URL\" --migrations-dir ./migrations --schema-file ./schema.sql down",
    "db:status": "dbmate --url \"$DATABASE_URL\" --migrations-dir ./migrations status",
    "db:new": "dbmate --url \"$DATABASE_URL\" --migrations-dir ./migrations new",
    "db:dump": "dbmate --url \"$DATABASE_URL\" --schema-file ./schema.sql dump",
    "build": "tsc --project tsconfig.json",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "postgres": "^3.4.4"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.4.0"
  }
}
