{
  "name": "@saas/web",
  "version": "0.1.0",
  "private": true,
  "description": "Vite + React + TanStack Router frontend",
  "scripts": {
    "dev":               "vite --port 3000",
    "build":             "vite build",
    "preview":           "vite preview --port 3000",
    "lint":              "tsc --noEmit",
    "test":              "vitest run",
    "playwright":        "playwright test",
    "playwright:ui":     "playwright test --ui",
    "playwright:report": "playwright show-report"
  },
  "dependencies": {
    "@hookform/resolvers":    "^3.9.0",
    "@saas/config":           "workspace:*",
    "@saas/ui":               "workspace:*",
    "@tanstack/react-query":  "^5.56.0",
    "@tanstack/react-router": "^1.81.0",
    "date-fns":               "^3.6.0",
    "lucide-react":           "^0.441.0",
    "react":                  "^18.3.0",
    "react-dom":              "^18.3.0",
    "react-hook-form":        "^7.53.0",
    "tailwindcss":            "^3.4.0",
    "zustand":                "^5.0.0",
    "zod":                    "^3.23.0"
  },
  "devDependencies": {
    "@playwright/test":    "^1.58.2",
    "@types/react":        "^18.3.0",
    "@types/react-dom":    "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer":        "^10.4.0",
    "postcss":             "^8.4.0",
    "typescript":          "^5.4.0",
    "vite":                "^5.4.0",
    "vitest":              "^2.0.0"
  }
}