{
  "name": "@saas/api",
  "version": "0.1.0",
  "private": true,
  "description": "Fastify API server — REST + GraphQL, Inversify DI, Pino logging",
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "build": "tsc --project tsconfig.json",
    "start": "tsx src/main.ts",
    "lint": "eslint src/",
    "test": "vitest run",
    "test:watch": "vitest",
    "e2e": "cucumber-js"
  },
  "dependencies": {
    "@apollo/server": "^4.11.0",
    "@as-integrations/fastify": "^3.1.0",
    "@fastify/cookie": "^11.0.0",
    "@fastify/cors": "^11.0.0",
    "@fastify/helmet": "^13.0.0",
    "@fastify/jwt": "^10.0.0",
    "@fastify/rate-limit": "^10.0.0",
    "@fastify/swagger": "^9.0.0",
    "@fastify/swagger-ui": "^5.0.0",
    "@saas/config": "workspace:*",
    "@saas/core": "workspace:*",
    "@saas/db": "workspace:*",
    "fastify": "^5.2.1",
    "graphql": "^16.9.0",
    "inversify": "^6.0.2",
    "nodemailer": "^6.9.0",
    "pino": "^9.3.0",
    "pino-pretty": "^11.2.0",
    "prom-client": "^15.1.3",
    "reflect-metadata": "^0.2.2",
    "stripe": "^16.5.0",
    "tsx": "^4.19.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@cucumber/cucumber": "^11.0.0",
    "@cucumber/pretty-formatter": "^1.0.0",
    "@types/node": "^20.0.0",
    "@types/nodemailer": "^6.4.0",
    "typescript": "^5.4.0",
    "vitest": "^2.0.0"
